{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "sortImports": true,
  "proseWrap": "always",
  "insertFinalNewline": true,
  "sortPackageJson": {
    "sortScripts": true
  },
  "ignorePatterns": ["dist", "node_modules", ".cache", ".pnpm-store", ".local", "pnpm-lock.yaml"]
}
