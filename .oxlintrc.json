{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import", "promise", "node", "vitest"],
  "env": {
    "node": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error"
  },
  "rules": {
    "no-await-in-loop": "off"
  },
  "ignorePatterns": ["dist", "node_modules", ".local", ".cache"]
}
