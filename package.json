{
  "name": "0xa3b-marketplace",
  "private": true,
  "scripts": {
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.47.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "body-leading-blank": [
        2,
        "always"
      ],
      "footer-leading-blank": [
        2,
        "always"
      ],
      "header-max-length": [
        2,
        "always",
        72
      ],
      "subject-case": [
        0
      ],
      "subject-full-stop": [
        2,
        "never",
        "."
      ]
    }
  },
  "packageManager": "pnpm@11.0.3"
}
